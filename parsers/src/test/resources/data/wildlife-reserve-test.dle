@doc healthScore "Ordinal health score, 1..5."

conservationStatus ‚äë calculatedList
‚àÉconservationStatus.‚ä§ ‚äë Species
‚ä§ ‚äë ‚àÄconservationStatus.{"Least Concern","Vulnerable","Endangered","Critical"}
‚â§1 conservationStatus.‚ä§
@db conservationStatus "conservation_status"
@label conservationStatus "Conservation Status"
@doc conservationStatus "Calculated conservation category selected from a model-defined list of terms."

surveyPriority ‚äë calculatedList
