recordsAnimalStatement ‚äë RelationshipStatement
recordsAnimalStatement ‚äë ‚àÉstatementRelationship.{recordsAnimal}

############################################################
# Ownership-like lifecycle states, rewritten for wildlife data
############################################################

recordCurationState ‚äë calculatedList
‚àÉrecordCurationState.‚ä§ ‚äë Animal
‚ä§ ‚äë ‚àÄrecordCurationState.{"Unassigned","Nominated","Curated","Maintained"}
‚â§1 recordCurationState.‚ä§
@db recordCurationState "record_curation_state"
@label recordCurationState "Record Curation State"
@doc recordCurationState "Calculated curation state for an animal record based on responsible researcher assignment, acceptance, health score, and review freshness."

curationAccepted ‚äë attribute
‚àÉcurationAccepted.‚ä§ ‚äë Animal
‚ä§ ‚äë ‚àÄcurationAccepted.{"No","Yes"}
‚â§1 curationAccepted.‚ä§
@db curationAccepted "curation_accepted"
@label curationAccepted "Curation Accepted"
@doc curationAccepted "Whether a nominated curator has accepted responsibility for the animal record."

hasCurator ‚äë relationship
‚àÉhasCurator.‚ä§ ‚äë Researcher
‚ä§ ‚äë ‚àÄhasCurator.Animal
@db hasCurator "Has Curator"
@label hasCurator "Has Curator"
@doc hasCurator "Researcher responsible for curating an animal record."

UnassignedRecord ‚â° Animal ‚äì ¬¨‚àÉhasCurator‚Åª.Researcher
UnassignedRecord ‚â° ‚àÉrecordCurationState.{"Unassigned"}
NominatedRecord ‚â° Animal ‚äì ‚àÉhasCurator‚Åª.Researcher ‚äì ‚àÉcurationAccepted.{"No"}
NominatedRecord ‚â° ‚àÉrecordCurationState.{"Nominated"}
CuratedRecord ‚â° Animal ‚äì ‚àÉhasCurator‚Åª.Researcher ‚äì ‚àÉcurationAccepted.{"Yes"} ‚äì ¬¨‚àÉhealthScore.‚ä§
CuratedRecord ‚â° ‚àÉrecordCurationState.{"Curated"}
MaintainedRecord ‚â° Animal ‚äì ‚àÉhasCurator‚Åª.Researcher ‚äì ‚àÉcurationAccepted.{"Yes"} ‚äì ‚àÉhealthScore.‚ä§
MaintainedRecord ‚â° ‚àÉrecordCurationState.{"Maintained"}

############################################################
# Derived classes
############################################################

HighHealth ‚â° ‚àÉhealthScore.{"4", "5"}
LowHealth ‚â° ‚àÉhealthScore.{"1", "2"}
HighSurveyPriority ‚â° ‚àÉsurveyPriority.{"High","Urgent"}
LowSurveyPriority ‚â° ‚àÉsurveyPriority.{"Low","Medium"}
PriorityAnimal ‚â° Animal ‚®Ö (LowHealth ‚®Ü ‚àÉbelongsToSpecies.(Species ‚äì HighSurveyPriority))

JuvenileAnimal ‚â° Animal ‚äì ‚àÉlifeStage.{"Juvenile"}
AdultAnimal ‚â° Animal ‚äì ‚àÉlifeStage.{"Adult"}
VerifiedObservation ‚â° Observation ‚äì ‚àÉverified.{true}
UnverifiedObservation ‚â° Observation ‚äì ‚àÉverified.{false}

HasMigrationDate ‚â° ‚àÉmigrationDate.‚ä§
HasLastObservation ‚â° ‚àÉlastObservedAt.‚ä§
HasReviewDate ‚â° ‚àÉreviewDate.‚ä§

EndangeredSpecies ‚â° Species ‚äì ‚àÉpopulationEstimate.xsd:integer[<1000]
CommonSpecies ‚â° Species ‚äì ‚àÉpopulationEstimate.xsd:integer[‚â•10000]
HighQualityHabitat ‚â° Habitat ‚äì ‚àÉhabitatQuality.xsd:decimal[‚â•4 ‚äì ‚â§5]
LowQualityHabitat ‚â° Habitat ‚äì ‚àÉhabitatQuality.xsd:decimal[‚â•1 ‚äì <3]

############################################################
# Calculated category definitions
############################################################

‚àÉconservationStatus.{"Critical"} ‚â° ‚àÉpopulationEstimate.xsd:integer[<250]
‚àÉconservationStatus.{"Endangered"} ‚â° ‚àÉpopulationEstimate.xsd:integer[‚â•250 ‚äì <1000]
‚àÉconservationStatus.{"Vulnerable"} ‚â° ‚àÉpopulationEstimate.xsd:integer[‚â•1000 ‚äì <10000]
‚àÉconservationStatus.{"Least Concern"} ‚â° ‚àÉpopulationEstimate.xsd:integer[‚â•10000]

‚àÉsurveyPriority.{"Urgent"} ‚â° ‚àÉpopulationRisk.xsd:decimal[‚â•4]
‚àÉsurveyPriority.{"High"} ‚â° ‚àÉpopulationRisk.xsd:decimal[‚â•3 ‚äì <4]
‚àÉsurveyPriority.{"Medium"} ‚â° ‚àÉpopulationRisk.xsd:decimal[‚â•2 ‚äì <3]
‚àÉsurveyPriority.{"Low"} ‚â° ‚àÉpopulationRisk.xsd:decimal[<2]

############################################################
# Predicate extensions and predicate restrictions
############################################################

greaterThan(x,y) ‚âù x > y
lessThan(x,y) ‚âù x < y
afterNow(x) ‚âù x > now()
beforeNow(x) ‚âù x < now()
onOrBeforeNow(x) ‚âù x ‚â§ now()
enclosesNow(x,y) ‚âù x ‚â§ now() ‚àß now() ‚â§ y
withinNextYear(x) ‚âù now() < x ‚àß x < addDuration(now(), P1Y)

PopulationIncreasing ‚â° ‚àÉpopulationEstimate,previousPopulationEstimate.greaterThan
PopulationDeclining ‚â° ‚àÉpopulationEstimate,previousPopulationEstimate.lessThan
MigrationInFuture ‚â° ‚àÉmigrationDate.afterNow
ObservationStale ‚â° ‚àÉlastObservedAt.beforeNow
ReviewDueNow ‚â° ‚àÉreviewDate.onOrBeforeNow
ActiveSurveyWindow ‚â° ‚àÉsurveyStart,surveyEnd.enclosesNow
MigrationSoon ‚â° ‚àÉmigrationDate.withinNextYear

