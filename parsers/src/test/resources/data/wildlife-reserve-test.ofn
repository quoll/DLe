# Object Property: <http://example.org/wildlife-test#partOfTaxon> (Part Of Taxon)

AnnotationAssertion(rdfs:comment :partOfTaxon "Immediate taxonomic containment, such as species within genus or genus within family.")
AnnotationAssertion(rdfs:isDefinedBy :partOfTaxon "part_of_taxon")
AnnotationAssertion(rdfs:label :partOfTaxon "Part Of Taxon")
SubObjectPropertyOf(:partOfTaxon :broaderTaxon)
