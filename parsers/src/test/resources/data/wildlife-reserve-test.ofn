############################
#   Annotation Properties
############################

# Annotation Property: <http://example.org/wildlife-test#afterNow> (afterNow(x))

AnnotationAssertion(rdf:value :afterNow "x → x > now()")
AnnotationAssertion(rdfs:label :afterNow "afterNow(x)")

# Annotation Property: <http://example.org/wildlife-test#beforeNow> (beforeNow(x))

AnnotationAssertion(rdf:value :beforeNow "x → x < now()")
AnnotationAssertion(rdfs:label :beforeNow "beforeNow(x)")

# Annotation Property: <http://example.org/wildlife-test#enclosesNow> (enclosesNow(x,y))

AnnotationAssertion(rdf:value :enclosesNow "x,y → x ≤ now() ∧ now() ≤ y")
AnnotationAssertion(rdfs:label :enclosesNow "enclosesNow(x,y)")

# Annotation Property: <http://example.org/wildlife-test#example> (example)

AnnotationAssertion(rdfs:label :example "example")

# Annotation Property: <http://example.org/wildlife-test#greaterThan> (greaterThan(x,y))

AnnotationAssertion(dle:comment :greaterThan "###########################################################
Predicate extensions and predicate restrictions
###########################################################")
AnnotationAssertion(rdf:value :greaterThan "x,y → x > y")
AnnotationAssertion(rdfs:label :greaterThan "greaterThan(x,y)")

# Annotation Property: <http://example.org/wildlife-test#lessThan> (lessThan(x,y))

AnnotationAssertion(rdf:value :lessThan "x,y → x < y")
AnnotationAssertion(rdfs:label :lessThan "lessThan(x,y)")

# Annotation Property: <http://example.org/wildlife-test#note> (note)

AnnotationAssertion(rdfs:label :note "note")

# Annotation Property: <http://example.org/wildlife-test#onOrBeforeNow> (onOrBeforeNow(x))

AnnotationAssertion(rdf:value :onOrBeforeNow "x → x ≤ now()")
AnnotationAssertion(rdfs:label :onOrBeforeNow "onOrBeforeNow(x)")

# Annotation Property: <http://example.org/wildlife-test#warning> (warning)

AnnotationAssertion(rdfs:label :warning "warning")

# Annotation Property: <http://example.org/wildlife-test#withinNextYear> (withinNextYear(x))

AnnotationAssertion(rdf:value :withinNextYear "x → now() < x ∧ x < addDuration(now(), P1Y)")
AnnotationAssertion(rdfs:label :withinNextYear "withinNextYear(x)")

# Annotation Property: rdf:value (value)

AnnotationAssertion(rdfs:label rdf:value "value")


