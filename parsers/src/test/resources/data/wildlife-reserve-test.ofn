AnnotationAssertion(rdfs:comment :speciesHabitat "Habitat inferred for an animal through the habitat associated with its species.")
AnnotationAssertion(rdfs:label :speciesHabitat "speciesHabitat")

# Object Property: <http://example.org/wildlife-test#statementRelationship> (statementRelationship)

AnnotationAssertion(rdfs:comment :statementRelationship "The predicate resource in a triple.")
AnnotationAssertion(rdfs:label :statementRelationship "statementRelationship")
ObjectPropertyDomain(:statementRelationship :RelationshipStatement)
ObjectPropertyRange(:statementRelationship rdf:Property)

# Object Property: <http://example.org/wildlife-test#studiedBy> (studiedBy)

AnnotationAssertion(dle:comment :studiedBy "###########################################################
Inverses named for convenience
###########################################################")
AnnotationAssertion(rdfs:label :studiedBy "studiedBy")
EquivalentObjectProperties(:studiedBy ObjectInverseOf(:studies))

# Object Property: <http://example.org/wildlife-test#studies> (Studies)

AnnotationAssertion(rdfs:comment :studies "Research relationship from a researcher to an animal, species, or habitat.")
AnnotationAssertion(rdfs:isDefinedBy :studies "studies")
AnnotationAssertion(rdfs:label :studies "Studies")
SubObjectPropertyOf(:studies :relationship)
ObjectPropertyDomain(:studies :Researcher)
ObjectPropertyRange(:studies ObjectUnionOf(:Animal :Habitat :Species))


############################
#   Data Properties
############################

# Data Property: <http://example.org/wildlife-test#attribute> (attribute)

AnnotationAssertion(rdfs:comment :attribute "A scalar attribute belonging to a wildlife concept or to an asserted relationship.")
AnnotationAssertion(rdfs:label :attribute "attribute")
DataPropertyDomain(:attribute ObjectUnionOf(:RelationshipStatement :WildlifeConcept))
DataPropertyRange(:attribute DataUnionOf(xsd:boolean xsd:date xsd:dateTime xsd:decimal xsd:integer xsd:string))

# Data Property: <http://example.org/wildlife-test#calculatedList> (Calculated List)

AnnotationAssertion(rdfs:comment :calculatedList "Subproperties of this are calculated string values selected from a model-defined list of enumerated terms.")
AnnotationAssertion(rdfs:label :calculatedList "Calculated List")
SubDataPropertyOf(:calculatedList :calculatedValue)
DataPropertyRange(:calculatedList xsd:string)

# Data Property: <http://example.org/wildlife-test#calculatedNumber> (Calculated Number)

AnnotationAssertion(rdfs:comment :calculatedNumber "Subproperties of this are numeric calculated values; this property is not intended for direct use.")
AnnotationAssertion(rdfs:label :calculatedNumber "Calculated Number")
SubDataPropertyOf(:calculatedNumber :calculatedValue)
DataPropertyRange(:calculatedNumber DataUnionOf(xsd:decimal xsd:integer))

# Data Property: <http://example.org/wildlife-test#calculatedValue> (Calculated)

AnnotationAssertion(rdfs:comment :calculatedValue "Subproperties of this are system-calculated values; this property is not intended for direct use.")
AnnotationAssertion(rdfs:label :calculatedValue "Calculated")
SubDataPropertyOf(:calculatedValue :attribute)

# Data Property: <http://example.org/wildlife-test#confidenceLevel> (Confidence Level)

AnnotationAssertion(rdfs:comment :confidenceLevel "Attribute on a Studies relationship indicating confidence in the relationship.")
AnnotationAssertion(rdfs:isDefinedBy :confidenceLevel "confidence_level")
AnnotationAssertion(rdfs:label :confidenceLevel "Confidence Level")
SubDataPropertyOf(:confidenceLevel :attribute)
FunctionalDataProperty(:confidenceLevel)
DataPropertyDomain(:confidenceLevel :studiesStatement)
DataPropertyRange(:confidenceLevel DataOneOf("High" "Low" "Medium"))

# Data Property: <http://example.org/wildlife-test#conservationStatus> (Conservation Status)

AnnotationAssertion(dle:comment :conservationStatus "###########################################################
Calculated category definitions
###########################################################")
AnnotationAssertion(rdfs:comment :conservationStatus "Calculated conservation category selected from a model-defined list of terms.")
AnnotationAssertion(rdfs:isDefinedBy :conservationStatus "conservation_status")
AnnotationAssertion(rdfs:label :conservationStatus "Conservation Status")
SubDataPropertyOf(:conservationStatus :calculatedList)
FunctionalDataProperty(:conservationStatus)
DataPropertyDomain(:conservationStatus :Species)
DataPropertyRange(:conservationStatus DataOneOf("Critical" "Endangered" "Least Concern" "Vulnerable"))

# Data Property: <http://example.org/wildlife-test#curationAccepted> (Curation Accepted)

AnnotationAssertion(rdfs:comment :curationAccepted "Whether a nominated curator has accepted responsibility for the animal record.")
AnnotationAssertion(rdfs:isDefinedBy :curationAccepted "curation_accepted")
AnnotationAssertion(rdfs:label :curationAccepted "Curation Accepted")
SubDataPropertyOf(:curationAccepted :attribute)
FunctionalDataProperty(:curationAccepted)
DataPropertyDomain(:curationAccepted :Animal)
DataPropertyRange(:curationAccepted DataOneOf("No" "Yes"))

# Data Property: <http://example.org/wildlife-test#description> (Description)

AnnotationAssertion(rdfs:comment :description "Concise description of a wildlife concept.")
AnnotationAssertion(rdfs:isDefinedBy :description "description")
AnnotationAssertion(rdfs:label :description "Description")
SubDataPropertyOf(:description :attribute)
FunctionalDataProperty(:description)
DataPropertyDomain(:description :WildlifeConcept)
DataPropertyRange(:description xsd:string)

# Data Property: <http://example.org/wildlife-test#habitatQuality> (Habitat Quality)

AnnotationAssertion(rdfs:comment :habitatQuality "Ordinal habitat quality score from 1 to 5.")
AnnotationAssertion(rdfs:isDefinedBy :habitatQuality "habitat_quality")
AnnotationAssertion(rdfs:label :habitatQuality "Habitat Quality")
SubDataPropertyOf(:habitatQuality :attribute)
FunctionalDataProperty(:habitatQuality)
DataPropertyDomain(:habitatQuality :Habitat)
DataPropertyRange(:habitatQuality DatatypeRestriction(xsd:decimal xsd:minInclusive "1"^^xsd:integer xsd:maxInclusive "5"^^xsd:integer))

# Data Property: <http://example.org/wildlife-test#habitatRisk> (Habitat Risk)

AnnotationAssertion(rdfs:comment :habitatRisk "Calculated risk score derived from habitat quality and monitoring status.")
AnnotationAssertion(rdfs:isDefinedBy :habitatRisk "habitat_risk")
AnnotationAssertion(rdfs:label :habitatRisk "Habitat Risk")
SubDataPropertyOf(:habitatRisk :calculatedNumber)
FunctionalDataProperty(:habitatRisk)
DataPropertyDomain(:habitatRisk :Habitat)
DataPropertyRange(:habitatRisk xsd:decimal)

# Data Property: <http://example.org/wildlife-test#healthScore> (Health Score)

AnnotationAssertion(rdfs:comment :healthScore "Ordinal health score, 1..5.")
AnnotationAssertion(rdfs:isDefinedBy :healthScore "health_score")
AnnotationAssertion(rdfs:label :healthScore "Health Score")
SubDataPropertyOf(:healthScore :attribute)
FunctionalDataProperty(:healthScore)
DataPropertyDomain(:healthScore :Animal)
DataPropertyRange(:healthScore DataOneOf("1" "2" "3" "4" "5"))

# Data Property: <http://example.org/wildlife-test#healthScoreValue> (healthScoreValue)

AnnotationAssertion(dle:comment :healthScoreValue "###########################################################
Numeric equivalents of enumerated scores
###########################################################")
AnnotationAssertion(rdfs:comment :healthScoreValue "Numeric equivalent to the healthScore attribute.")
AnnotationAssertion(rdfs:label :healthScoreValue "healthScoreValue")
FunctionalDataProperty(:healthScoreValue)
DataPropertyDomain(:healthScoreValue :Animal)
DataPropertyRange(:healthScoreValue xsd:decimal)

# Data Property: <http://example.org/wildlife-test#id> (id)

AnnotationAssertion(dle:comment :id "`matches` references the OWL xsd:pattern facet. `key()` references owl:hasKey.")
AnnotationAssertion(rdfs:comment :id "Opaque unique identifier for a modeled wildlife concept.")
AnnotationAssertion(rdfs:isDefinedBy :id "id")
AnnotationAssertion(rdfs:label :id "id")
AnnotationAssertion(rdfs:seeAlso :id "triplestore.subject")
FunctionalDataProperty(:id)
DataPropertyDomain(:id :WildlifeConcept)
DataPropertyRange(:id DatatypeRestriction(xsd:string xsd:pattern "[A-Z]{3}-[0-9]{6}"))

# Data Property: <http://example.org/wildlife-test#lastObservedAt> (Last Observed At)

AnnotationAssertion(rdfs:comment :lastObservedAt "Date and time when an animal was last observed.")
AnnotationAssertion(rdfs:isDefinedBy :lastObservedAt "last_observed_at")
AnnotationAssertion(rdfs:label :lastObservedAt "Last Observed At")
SubDataPropertyOf(:lastObservedAt :attribute)
FunctionalDataProperty(:lastObservedAt)
DataPropertyDomain(:lastObservedAt :Animal)
DataPropertyRange(:lastObservedAt xsd:dateTime)

# Data Property: <http://example.org/wildlife-test#lifeStage> (Life Stage)

AnnotationAssertion(dle:comment :lifeStage "###########################################################
Enumerated attributes
###########################################################")
AnnotationAssertion(rdfs:comment :lifeStage "Observed maturity stage of an animal.")
AnnotationAssertion(rdfs:isDefinedBy :lifeStage "life_stage")
AnnotationAssertion(rdfs:label :lifeStage "Life Stage")
SubDataPropertyOf(:lifeStage :attribute)
FunctionalDataProperty(:lifeStage)
DataPropertyDomain(:lifeStage :Animal)
DataPropertyRange(:lifeStage DataOneOf("Adult" "Juvenile" "Subadult" "Unknown"))

# Data Property: <http://example.org/wildlife-test#migrationDate> (Migration Date)

AnnotationAssertion(rdfs:comment :migrationDate "Expected or observed migration date.")
AnnotationAssertion(rdfs:isDefinedBy :migrationDate "migration_date")
AnnotationAssertion(rdfs:label :migrationDate "Migration Date")
SubDataPropertyOf(:migrationDate :attribute)
FunctionalDataProperty(:migrationDate)
DataPropertyDomain(:migrationDate :Animal)
DataPropertyRange(:migrationDate xsd:date)

# Data Property: <http://example.org/wildlife-test#name> (Name)

AnnotationAssertion(dle:comment :name "###########################################################
Basic attributes and identifiers
###########################################################")
AnnotationAssertion(rdfs:comment :name "Unique display name for a wildlife concept.")
AnnotationAssertion(rdfs:isDefinedBy :name "name")
AnnotationAssertion(rdfs:label :name "Name")
FunctionalDataProperty(:name)
