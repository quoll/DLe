# Object Property: <http://example.org/wildlife-test#belongsToSpecies> (Belongs To Species)

AnnotationAssertion(dle:comment :belongsToSpecies "###########################################################
Relationships
###########################################################")
AnnotationAssertion(dle:comment :belongsToSpecies "###########################################################
Role chains and inferred relationships
###########################################################")
AnnotationAssertion(rdfs:comment :belongsToSpecies "Species classification of an individual animal.")
AnnotationAssertion(rdfs:isDefinedBy :belongsToSpecies "belongs_to_species")
AnnotationAssertion(rdfs:label :belongsToSpecies "Belongs To Species")
SubObjectPropertyOf(:belongsToSpecies :relationship)
FunctionalObjectProperty(:belongsToSpecies)
ObjectPropertyDomain(:belongsToSpecies :Animal)
ObjectPropertyRange(:belongsToSpecies :Species)

# Object Property: <http://example.org/wildlife-test#broaderTaxon> (broaderTaxon)

AnnotationAssertion(rdfs:label :broaderTaxon "broaderTaxon")
TransitiveObjectProperty(:broaderTaxon)

# Object Property: <http://example.org/wildlife-test#containedIn> (containedIn)

AnnotationAssertion(rdfs:label :containedIn "containedIn")
TransitiveObjectProperty(:containedIn)

# Object Property: <http://example.org/wildlife-test#contains> (contains)

AnnotationAssertion(rdfs:label :contains "contains")
EquivalentObjectProperties(:contains ObjectInverseOf(:locatedIn))

# Object Property: <http://example.org/wildlife-test#containsTransitively> (containsTransitively)

AnnotationAssertion(rdfs:label :containsTransitively "containsTransitively")
EquivalentObjectProperties(:containsTransitively ObjectInverseOf(:containedIn))

# Object Property: <http://example.org/wildlife-test#curates> (curates)

AnnotationAssertion(rdfs:comment :curates "Researcher curates data for an animal, species, habitat, or route.")
AnnotationAssertion(rdfs:label :curates "curates")
SubObjectPropertyOf(:curates :hasResponsibilityRelation)
DisjointObjectProperties(:curates :leadsSurveyFor)
DisjointObjectProperties(:curates :monitors)

# Object Property: <http://example.org/wildlife-test#followsRoute> (Follows Route)

AnnotationAssertion(rdfs:comment :followsRoute "Survey route followed when making an observation.")
AnnotationAssertion(rdfs:isDefinedBy :followsRoute "follows_route")
AnnotationAssertion(rdfs:label :followsRoute "Follows Route")
SubObjectPropertyOf(:followsRoute :relationship)
ObjectPropertyDomain(:followsRoute :Observation)
ObjectPropertyRange(:followsRoute :SurveyRoute)

# Object Property: <http://example.org/wildlife-test#hasCurator> (Has Curator)

AnnotationAssertion(rdfs:comment :hasCurator "Researcher responsible for curating an animal record.")
AnnotationAssertion(rdfs:isDefinedBy :hasCurator "Has Curator")
AnnotationAssertion(rdfs:label :hasCurator "Has Curator")
SubObjectPropertyOf(:hasCurator :relationship)
ObjectPropertyDomain(:hasCurator :Researcher)
ObjectPropertyRange(:hasCurator :Animal)

# Object Property: <http://example.org/wildlife-test#hasMember> (hasMember)

AnnotationAssertion(rdfs:label :hasMember "hasMember")
EquivalentObjectProperties(:hasMember ObjectInverseOf(:memberOf))

# Object Property: <http://example.org/wildlife-test#hasResponsibilityRelation> (Has Responsibility)

AnnotationAssertion(rdfs:comment :hasResponsibilityRelation "General responsibility relation; specialized by more precise responsibility types.")
AnnotationAssertion(rdfs:isDefinedBy :hasResponsibilityRelation "Has Responsibility")
AnnotationAssertion(rdfs:label :hasResponsibilityRelation "Has Responsibility")
SubObjectPropertyOf(:hasResponsibilityRelation :relationship)
ObjectPropertyDomain(:hasResponsibilityRelation :Researcher)
ObjectPropertyRange(:hasResponsibilityRelation ObjectUnionOf(:Animal :Habitat :Species :SurveyRoute))

# Object Property: <http://example.org/wildlife-test#hasTaxonPart> (hasTaxonPart)

AnnotationAssertion(rdfs:label :hasTaxonPart "hasTaxonPart")
EquivalentObjectProperties(:hasTaxonPart ObjectInverseOf(:partOfTaxon))

# Object Property: <http://example.org/wildlife-test#inDomain> (In Domain)

AnnotationAssertion(dle:comment :inDomain "###########################################################
Domain assignment
###########################################################")
AnnotationAssertion(rdfs:comment :inDomain "Primary subject grouping for a modeled wildlife concept.")
AnnotationAssertion(rdfs:isDefinedBy :inDomain "domain_id")
AnnotationAssertion(rdfs:label :inDomain "In Domain")
FunctionalObjectProperty(:inDomain)
ObjectPropertyDomain(:inDomain :WildlifeConcept)
ObjectPropertyRange(:inDomain :Domain)

# Object Property: <http://example.org/wildlife-test#inhabits> (Inhabits)

AnnotationAssertion(rdfs:comment :inhabits "Habitat normally used by an animal or species.")
AnnotationAssertion(rdfs:isDefinedBy :inhabits "inhabits")
AnnotationAssertion(rdfs:label :inhabits "Inhabits")
SubObjectPropertyOf(:inhabits :relationship)
ObjectPropertyDomain(:inhabits ObjectUnionOf(:Animal :Species))
ObjectPropertyRange(:inhabits :Habitat)

# Object Property: <http://example.org/wildlife-test#leadsSurveyFor> (leadsSurveyFor)

AnnotationAssertion(rdfs:comment :leadsSurveyFor "Researcher leads surveys for an animal, species, habitat, or route.")
AnnotationAssertion(rdfs:label :leadsSurveyFor "leadsSurveyFor")
SubObjectPropertyOf(:leadsSurveyFor :hasResponsibilityRelation)
DisjointObjectProperties(:leadsSurveyFor :monitors)

# Object Property: <http://example.org/wildlife-test#locatedIn> (Located In)

AnnotationAssertion(dle:comment :locatedIn "###########################################################
Hierarchy and transitive closure
###########################################################")
AnnotationAssertion(rdfs:comment :locatedIn "Immediate geographic containment. This is instance-level location containment, not rdfs:subClassOf semantics.")
AnnotationAssertion(rdfs:isDefinedBy :locatedIn "located_in")
AnnotationAssertion(rdfs:label :locatedIn "Located In")
SubObjectPropertyOf(:locatedIn :containedIn)
SubObjectPropertyOf(:locatedIn :relationship)
FunctionalObjectProperty(:locatedIn)
ObjectPropertyDomain(:locatedIn ObjectUnionOf(:Habitat :Observation :Region))
ObjectPropertyRange(:locatedIn ObjectUnionOf(:Habitat :Region))

# Object Property: <http://example.org/wildlife-test#locatedInWiderRegion> (locatedInWiderRegion)

AnnotationAssertion(rdfs:comment :locatedInWiderRegion "Wider geographic region inferred through location containment.")
AnnotationAssertion(rdfs:label :locatedInWiderRegion "locatedInWiderRegion")

# Object Property: <http://example.org/wildlife-test#memberOf> (Member Of)

AnnotationAssertion(rdfs:comment :memberOf "Research team membership.")
AnnotationAssertion(rdfs:isDefinedBy :memberOf "member_of")
AnnotationAssertion(rdfs:label :memberOf "Member Of")
SubObjectPropertyOf(:memberOf :relationship)
ObjectPropertyDomain(:memberOf :Researcher)
ObjectPropertyRange(:memberOf :ResearchTeam)

# Object Property: <http://example.org/wildlife-test#monitoredRegionBy> (monitoredRegionBy)

AnnotationAssertion(rdfs:comment :monitoredRegionBy "Researcher inferred to monitor a wider region through responsibility for a contained location.")
AnnotationAssertion(rdfs:label :monitoredRegionBy "monitoredRegionBy")

# Object Property: <http://example.org/wildlife-test#monitors> (monitors)

AnnotationAssertion(rdfs:comment :monitors "Researcher monitors an animal, species, habitat, or route.")
AnnotationAssertion(rdfs:label :monitors "monitors")
SubObjectPropertyOf(:monitors :hasResponsibilityRelation)

# Object Property: <http://example.org/wildlife-test#narrowerTaxon> (narrowerTaxon)

AnnotationAssertion(rdfs:label :narrowerTaxon "narrowerTaxon")
EquivalentObjectProperties(:narrowerTaxon ObjectInverseOf(:broaderTaxon))

